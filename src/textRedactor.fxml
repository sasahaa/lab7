<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #FFFFE0;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="textRedactor">
    <top>
        <VBox>
            <AnchorPane prefHeight="45.0" style="-fx-background-color: #9370DB;">
                <children>
                    <MenuButton layoutX="14.0" layoutY="7.0" minWidth="100.0" prefWidth="100.0" text="%menu.file">
                        <items>
                            <MenuItem fx:id="openItem" text="%menu.open" />
                            <MenuItem fx:id="saveItem" text="%menu.save" />
                        </items>
                    </MenuButton>

                    <MenuButton fx:id="bu" layoutX="125.0" layoutY="7.0" minWidth="120.0" prefWidth="120.0" text="%button.language">
                        <items>
                            <MenuItem onAction="#setGD" text="Gàidhlig" />
                            <MenuItem onAction="#setSR" text="Српски" />
                            <MenuItem onAction="#setSK" text="Slovenčina" />
                            <MenuItem onAction="#setUK" text="Українська" />
                        </items>
                    </MenuButton>
                    <Button fx:id="exitButton" layoutX="500.0" layoutY="7.0" minWidth="80.0" prefWidth="80.0" text="%button.exit" />
                </children>
            </AnchorPane>
        </VBox>
    </top>
    <center>
        <TextArea fx:id="textArea" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
    </center>
</BorderPane>
